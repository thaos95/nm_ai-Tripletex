{
  "create_employee": {
    "endpoint": "/employee",
    "method": "POST",
    "payload_fields": {
      "firstName": "fields.first_name",
      "lastName": "fields.last_name",
      "email": "fields.email",
      "dateOfBirth": "fields.birthDate|fields.dateOfBirth",
      "userType": "fields.userType|default:STANDARD",
      "nationalIdentityNumber": "fields.nationalIdentityNumber",
      "employments": "[{isActive:true, startDate:fields.startDate|default:today, percentageOfFullTimeEquivalent:fields.employmentPercentage, occupationCode:{code:fields.occupationCode}}]"
    },
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "first_name", "last_name", "email", "employee_type", "birthDate",
      "dateOfBirth", "startDate", "userType", "phoneNumberMobile",
      "isAccountAdmin", "address", "nationalIdentityNumber", "bankAccountNumber",
      "employmentPercentage", "annualSalary", "occupationCode"
    ],
    "gotchas": [
      "startDate belongs inside employments array, NOT at the top level — API rejects top-level startDate",
      "dateOfBirth may appear as birthDate in parsed fields",
      "userType enum: STANDARD, EXTENDED, NO_ACCESS",
      "nationalIdentityNumber is a valid top-level field for Norwegian employees",
      "employmentPercentage maps to percentageOfFullTimeEquivalent inside employments",
      "occupationCode maps to occupationCode:{code} nested object inside employments"
    ],
    "prerequisites": [],
    "tier": 1
  },
  "update_employee": {
    "endpoint": "/employee/{id}",
    "method": "PUT",
    "forbidden_fields": [],
    "allowed_parsed_fields": ["phoneNumberMobile", "email"],
    "gotchas": [
      "Must find existing employee first by email or name"
    ],
    "prerequisites": ["employee"],
    "tier": 1
  },
  "list_employees": {
    "endpoint": "/employee",
    "method": "GET",
    "forbidden_fields": [],
    "allowed_parsed_fields": ["fields", "count"],
    "gotchas": [],
    "prerequisites": [],
    "tier": 1
  },
  "create_customer": {
    "endpoint": "/customer",
    "method": "POST",
    "payload_fields": {
      "name": "fields.name",
      "email": "fields.email",
      "isCustomer": "fields.isCustomer|default:true",
      "isSupplier": "fields.isSupplier|default:false",
      "organizationNumber": "fields.organizationNumber",
      "phoneNumber": "fields.phoneNumber"
    },
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "name", "email", "isCustomer", "isSupplier", "organizationNumber", "phoneNumber"
    ],
    "gotchas": [
      "isCustomer defaults to true, isSupplier defaults to false",
      "Supplier registration uses this same endpoint with isSupplier=true"
    ],
    "prerequisites": [],
    "tier": 1
  },
  "update_customer": {
    "endpoint": "/customer/{id}",
    "method": "PUT",
    "forbidden_fields": [],
    "allowed_parsed_fields": ["phoneNumber", "email"],
    "gotchas": [],
    "prerequisites": ["customer"],
    "tier": 1
  },
  "search_customers": {
    "endpoint": "/customer",
