    "payload_fields": {
      "name": "fields.name",
      "priceExcludingVatCurrency": "fields.priceExcludingVatCurrency",
      "productNumber": "fields.productNumber"
    },
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "name", "priceExcludingVatCurrency", "productNumber", "vatPercentage"
    ],
    "gotchas": [],
    "prerequisites": [],
    "tier": 1
  },
  "create_project": {
    "endpoint": "/project",
    "method": "POST",
    "payload_fields": {
      "name": "fields.name",
      "startDate": "fields.startDate|default:today"
    },
    "forbidden_fields": [],
    "allowed_parsed_fields": ["name", "startDate"],
    "gotchas": [
      "Requires customer and projectManager linked by ID",
      "projectManager must be an existing employee with active employment"
    ],
    "prerequisites": ["customer", "project_manager"],
    "tier": 1
  },
  "create_department": {
    "endpoint": "/department",
    "method": "POST",
    "forbidden_fields": [],
    "allowed_parsed_fields": ["name", "departmentNumber", "departmentNames"],
    "gotchas": [
      "Multiple departments may be requested in one prompt — check for departmentNames list"
    ],
    "prerequisites": [],
    "tier": 1
  },
  "create_order": {
    "endpoint": "/order",
    "method": "POST",
    "forbidden_fields": [],
    "allowed_parsed_fields": ["orderDate", "deliveryDate"],
    "gotchas": [
      "Requires customer ID and at least one order line (product or description)"
    ],
    "prerequisites": ["customer", "product"],
    "tier": 1
  },
  "create_invoice": {
    "endpoint": "/invoice",
    "method": "POST",
    "payload_fields": {
      "invoiceDate": "fields.invoiceDate|default:today",
      "invoiceDueDate": "fields.invoiceDueDate|default:today"
    },
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "invoiceDate", "invoiceDueDate", "orderDate", "deliveryDate",
      "amount", "accountNumber", "sendByEmail", "markAsPaid",
      "paymentDate", "amountPaidCurrency", "paymentTypeId",
      "currency", "exchangeRate"
    ],
    "gotchas": [
      "Requires company bank account — auto-create if missing",
      "Invoice is created from an order (POST /order first, then POST /invoice with orders:[{id}])",
      "Payment registration uses PUT /invoice/{id}/:payment (separate call)"
    ],
    "prerequisites": ["customer", "order"],
    "tier": 2
  },
  "create_supplier_invoice": {
    "endpoint": "/incomingInvoice",
    "method": "POST",
    "needs_wrapper": "invoiceHeader",
    "wrapper_fields": {
      "invoiceDate": "fields.invoiceDate|default:today",
      "invoiceNumber": "fields.invoiceNumber",
      "vendorId": "resolved:supplier",
      "invoiceAmount": "fields.amount",
      "dueDate": "fields.invoiceDueDate|fields.invoiceDate|default:today"
    },
    "order_line_fields": {
      "amountInclVat": "fields.amount",
      "externalId": "fields.invoiceNumber|default:line-1",
      "accountId": "fields.accountNumber"
    },
    "forbidden_fields": ["vatType", "vatPercentage", "vatCode", "vatRate"],
    "allowed_parsed_fields": [
      "invoiceDate", "invoiceNumber", "amount", "accountNumber", "vatPercentage",
      "description", "invoiceDescription", "invoiceDueDate",
      "dueDate", "bankAccountNumber"
    ],
    "gotchas": [
      "orderLines do NOT accept vatType or vatPercentage — VAT is derived from account number",
      "Must use invoiceHeader wrapper — flat invoiceDate/supplier fields are rejected",
      "vendorId goes inside invoiceHeader, NOT supplier:{id} at top level",
      "Endpoint is /incomingInvoice not /supplierInvoice",
      "accountId in orderLines is the account NUMBER (e.g., 7300), not a resolved ID"
    ],
    "prerequisites": ["supplier"],
    "tier": 2
  },
  "create_credit_note": {
    "endpoint": "/invoice",
    "method": "POST",
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "invoiceDate", "invoiceDueDate", "orderDate", "deliveryDate", "amount", "creditNote"
    ],
    "gotchas": [
      "Created by calling POST /invoice/{original_invoice_id}/:createCreditNote",
      "Must find the original invoice first by customer + description/amount match"
    ],
    "prerequisites": ["customer", "invoice"],
    "tier": 2
  },
  "create_project_billing": {
    "endpoint": "/project + /order + /invoice",
    "method": "POST",
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "name", "startDate", "invoiceDate", "invoiceDueDate", "orderDate", "deliveryDate",
      "fixedPriceAmountCurrency", "billingPercentage", "hourlyRateCurrency", "amount",
      "budget", "budgetAmount"
    ],
    "gotchas": [
      "Multi-step: create project → create activity → register time entries → create supplier invoice → create order → create invoice",
      "budget and budgetAmount should be used as amount fallback if amount is missing",
      "Supplier invoice within project billing needs invoiceHeader wrapper with vendorId",
      "Requires company bank account for final invoice creation",
      "projectManager must have active employment — fall back to any existing employee"
    ],
    "prerequisites": ["customer", "project_manager"],
    "tier": 3
  },
  "create_dimension_voucher": {
    "endpoint": "/ledger/voucher",
    "method": "POST",
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "debitAccountNumber", "creditAccountNumber", "amount", "date",
      "description", "accountNumber", "dimensionName", "dimensionValue"
    ],
    "gotchas": [
      "Voucher postings must use account ID ({id: N}), NOT account number/name",
      "Resolve account IDs via GET /ledger/account?number=NNNN",
      "System-generated accounts reject number-based references"
    ],
    "prerequisites": [],
    "tier": 3
  },
  "create_payroll_voucher": {
    "endpoint": "/ledger/voucher",
    "method": "POST",
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "debitAccountNumber", "creditAccountNumber", "amount", "date", "description"
    ],
    "gotchas": [
      "Same as dimension voucher: must resolve account IDs first",
      "Voucher postings must balance (total debits = total credits)"
    ],
    "prerequisites": [],
    "tier": 2
  },
