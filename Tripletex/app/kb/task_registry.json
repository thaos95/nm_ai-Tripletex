  "register_payment": {
    "endpoint": "/invoice/{id}/:payment",
    "method": "PUT",
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "paymentDate", "amount", "amountPaidCurrency", "paymentTypeId",
      "exchangeRate", "currency"
    ],
    "gotchas": [
      "Uses PUT /invoice/{id}/:payment with query params (not JSON body)",
      "paidAmount should be the invoice total INCLUDING VAT, not the parsed amount",
      "Requires company bank account to exist",
      "Returns 404 if amount doesn't match — try invoice.amount, amountOutstanding, derived payment"
    ],
    "prerequisites": ["customer", "invoice"],
    "tier": 2
  },
  "reverse_payment": {
    "endpoint": "/invoice/{id}/:payment",
    "method": "PUT",
    "forbidden_fields": [],
    "allowed_parsed_fields": [
      "paymentDate", "amount", "amountPaidCurrency", "paymentTypeId"
    ],
    "gotchas": [
      "Same endpoint as register_payment but with negative paidAmount",
      "paidAmount should be NEGATIVE and match the original payment amount",
      "Try multiple amounts if 404: invoice total, excl VAT, outstanding, derived payment",
      "Requires company bank account"
    ],
    "prerequisites": ["customer", "invoice"],
    "tier": 2
  },
